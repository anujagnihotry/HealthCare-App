# Copy to .env locally. On Railway, set these in the service Variables tab.

NODE_ENV=production
PORT=3000

# Auth (generate a long random string for production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=7d

# Option A — Railway Postgres "DATABASE_URL" (recommended)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Option B — discrete DB vars (if not using DATABASE_URL)
# DB_HOST=
# DB_PORT=5432
# DB_USERNAME=
# DB_PASSWORD=
# DB_NAME=

# SSL: auto-enabled when DATABASE_URL is set in production. Force with:
# DB_SSL=true

# First deploy only: create tables from entities (then set to false and use migrations)
TYPEORM_SYNC=false

# File uploads (writable path inside the container)
UPLOAD_DIR=./uploads

# CORS — comma-separated web origins allowed to call the API with cookies/credentials
# Example: https://healthsuite.in,https://www.healthsuite.in
# Leave unset for same-origin / mobile apps that do not rely on browser CORS the same way.
# CORS_ORIGIN=
